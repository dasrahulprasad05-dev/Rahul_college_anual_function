rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is an admin
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + "_admin"));
    }
    
    // Check if user is a volunteer
    function isVolunteer() {
      return isAuthenticated() && (isAdmin() || exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + "_volunteer")));
    }
    
    // Users
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAdmin();
    }
    
    // Roles
    match /user_roles/{roleId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow write: if isAdmin();
    }
    
    // Events
    match /events/{eventId} {
      allow read: if true; // Public can see events
      allow write: if isAdmin();
      
      // Items under events (collectionGroup also covered here implicitly, but better explicitly below if using collectionGroup queries)
      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    match /{path=**}/items/{itemId} {
      allow read: if true;
    }
    
    // Tickets
    match /tickets/{ticketId} {
      // Users can read their own tickets. Admins and Volunteers can read all tickets.
      allow read: if isAdmin() || isVolunteer() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      // Users can create their own tickets
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // Admins and volunteers can update ticket status (check-in)
      allow update: if isAdmin() || isVolunteer();
      allow delete: if isAdmin();
    }
    
    // Event Volunteers
    match /event_volunteers/{assignmentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow write: if isAdmin();
    }
    
    // Gate Passes
    match /gate_passes/{passId} {
      // Admins can read all. Users can read their own.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      // Users can apply for a gate pass
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      // Admins can approve/reject
      allow update, delete: if isAdmin();
    }
    
    // Feedback
    match /feedback/{feedbackId} {
      // Anyone can read public feedback
      allow read: if true;
      // Users can submit feedback if authenticated
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
